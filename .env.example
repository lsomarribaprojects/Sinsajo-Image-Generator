# Sinsajo Image Generator v3 — API Keys
# You only need ONE key to get started. Add more for smart routing.

# ─── Gemini (recommended for free tier) ────────────────────────
# Best for: General purpose, free tier, image editing
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── OpenRouter (gateway to many models) ───────────────────────
# Best for: Access to multiple models via one gateway
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Ideogram (best for text in images) ────────────────────────
# Best for: Ad creatives, thumbnails, banners — 90-95% text accuracy
# Get your key at: https://ideogram.ai/manage-api
IDEOGRAM_API_KEY=

# ─── fal.ai / Flux (best for photorealism) ─────────────────────
# Best for: Lifestyle photography, product photos, photorealistic scenes
# Get your key at: https://fal.ai/dashboard/keys
FAL_API_KEY=

# ─── Recraft (best for design & branding) ──────────────────────
# Best for: Logos, mockups, SVG-style design, brand assets
# Get your key at: https://www.recraft.ai/docs
RECRAFT_API_KEY=

# ─── OpenAI (best all-rounder) ─────────────────────────────────
# Best for: Infographics, social posts, versatile generation
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
